# Cloudflare Pages caching headers
# Serve static assets with long-lived cache headers; HTML stays short-lived so updates deploy immediately.

# CSS (site.css fingerprints via URL; change filename on new major edits to bust cache)
/site.css
  Cache-Control: public, max-age=31536000, immutable

# Web manifest
/site.webmanifest
  Cache-Control: public, max-age=86400

# Images — content rarely changes; long TTL + stale-while-revalidate
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon
/images/favicon.png
  Cache-Control: public, max-age=604800

# LLM files — refresh weekly so AI crawlers see updates
/llms.txt
  Cache-Control: public, max-age=3600
/llms-full.txt
  Cache-Control: public, max-age=3600

# robots + sitemap — short TTL for crawler freshness
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600

# HTML (default) — short cache so deploys appear fast
/*.html
  Cache-Control: public, max-age=300, must-revalidate
